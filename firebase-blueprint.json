{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile with role-based access info.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["buyer", "seller", "admin"] },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "role"]
    },
    "Product": {
      "title": "Product",
      "description": "Store product details.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "sellerId": { "type": "string" },
        "imageUrl": { "type": "string" },
        "category": { "type": "string" },
        "stock": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "price", "sellerId"]
    },
    "Order": {
      "title": "Order",
      "description": "E-commerce order record.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "buyerId": { "type": "string" },
        "sellerId": { "type": "string" },
        "items": { "type": "array" },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "paid", "shipped", "delivered", "cancelled"] },
        "shippingAddress": { "type": "string" },
        "paymentIntentId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "buyerId", "sellerId", "items", "totalAmount", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Public user profile data."
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Store items available for purchase."
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Purchase transaction history."
    }
  }
}
